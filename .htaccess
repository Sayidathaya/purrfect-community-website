# Ensure directory requests resolve to index.php
DirectoryIndex index.php

# (Optional) Keep existing behavior for existing files/dirs; otherwise serve file directly.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If someone hits a path that doesn't exist, return 404 (do not rewrite to index.php)
